# Server-side only (used in /api/contact route)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_TO_EMAIL=

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_DISABLE_RECAPTCHA=false

# Public meta tag (rendered in HTML head)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# GitHub (used by stats section, server-side)
GITHUB_USERNAME=
GITHUB_PRIVATE_REPOS=0
GITHUB_TOKEN=

# Personal (server-side, used to calculate age)
BIRTH_DATE=1990-01-01

# Build-time (used by next-sitemap)
SITE_URL=https://example.com
